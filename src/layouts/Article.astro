---
import Base from './Base.astro';

interface Props {
  title: string;
  subtitle?: string;
  date: Date;
  kind?: string;
  readingMin?: number;
}
const { title, subtitle, date, kind, readingMin } = Astro.props;
const dateLabel = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} — Elua`} description={subtitle ?? title}>
  <article class="article">
    <div class="wrap">
      <a class="back" href="/dimension">← Four dimensions?</a>

      <header class="article__head prose-wrap">
        {kind && <p class="eyebrow">{kind}</p>}
        <h1>{title}</h1>
        {subtitle && <p class="lede article__sub">{subtitle}</p>}
        <p class="article__meta muted">
          <time datetime={date.toISOString()}>{dateLabel}</time>
          {readingMin && <span>· {readingMin} min read</span>}
        </p>
      </header>

      <div class="article__body prose prose-wrap">
        <slot />
      </div>

      <nav class="article__more prose-wrap">
        <a class="btn btn--ghost" href="/dimension">More on four dimensions →</a>
      </nav>
    </div>
  </article>
</Base>

<style>
  .article {
    padding-block: clamp(2rem, 6vw, 4.5rem) clamp(3rem, 8vw, 6rem);
  }
  .back {
    display: inline-block;
    font-size: var(--step--1);
    color: var(--muted-400);
    margin-bottom: 2rem;
  }
  .back:hover {
    color: var(--lamp-300);
  }
  .article__head {
    margin-inline: auto;
  }
  .article__head h1 {
    font-size: var(--step-4);
    margin-top: 0.6rem;
  }
  .article__sub {
    margin-top: 1rem;
    font-size: var(--step-1);
  }
  .article__meta {
    margin-top: 1.2rem;
    font-size: var(--step--1);
  }
  .article__body {
    margin-inline: auto;
    margin-top: 2.6rem;
  }
  .article__foot {
    margin-inline: auto;
    margin-top: 3rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--rule);
    font-size: var(--step--1);
  }
  .article__more {
    margin-inline: auto;
    margin-top: 2.4rem;
  }
</style>

<style is:global>
  /* prose — reading typography for the article body */
  .prose {
    font-size: var(--step-0);
    line-height: 1.75;
    color: var(--ceramic-200);
  }
  .prose > * + * {
    margin-top: 1.15em;
  }
  .prose h2 {
    font-size: var(--step-2);
    margin-top: 2.4em;
    margin-bottom: 0.2em;
    color: var(--lamp-300);
  }
  .prose h3 {
    font-size: var(--step-1);
    margin-top: 1.8em;
    color: var(--ceramic-100);
  }
  .prose p,
  .prose ul,
  .prose ol {
    max-width: 38rem;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.3em;
  }
  .prose li + li {
    margin-top: 0.4em;
  }
  .prose li::marker {
    color: var(--lamp-500);
  }
  .prose strong {
    color: var(--ceramic-100);
    font-weight: 620;
  }
  .prose em {
    color: var(--lamp-200, var(--lamp-300));
  }
  .prose blockquote {
    border-left: 2px solid var(--accent);
    padding: 0.2em 0 0.2em 1.2em;
    margin-left: 0;
    font-family: var(--serif);
    font-size: var(--step-1);
    font-style: italic;
    color: var(--ceramic-100);
  }
  .prose hr {
    border: 0;
    border-top: 1px solid var(--rule);
    margin-block: 2.4em;
    max-width: 38rem;
  }
  .prose code {
    font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
    font-size: 0.88em;
    background: rgba(36, 50, 70, 0.5);
    padding: 0.12em 0.4em;
    border-radius: 5px;
    color: var(--lamp-300);
  }
  .prose a {
    text-decoration: underline;
    text-decoration-color: rgba(227, 168, 87, 0.4);
  }
  /* a soft "drop-cap"-ish first line cue via the lede only; keep body calm */
</style>
