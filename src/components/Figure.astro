---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * Figure — a Medium-style body image for articles.
 *
 * Pass an imported image (so Astro optimises it) plus alt text and an optional
 * caption. Used from MDX dev-journal entries. `wide` lets a figure break past
 * the prose column for diagrams that want room to breathe.
 *
 * Animated GIFs are emitted as a plain <img> (referencing the original file)
 * rather than run through the <Image> optimiser, which would flatten them to a
 * single still frame.
 */
interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  wide?: boolean;
}
const { src, alt, caption, wide = false } = Astro.props;
const sizes = wide
  ? '(min-width: 980px) 52rem, 100vw'
  : '(min-width: 720px) 38rem, 100vw';
const isAnimated = src.format === 'gif';
---

<figure class:list={['figure', { 'figure--wide': wide }]}>
  {
    isAnimated ? (
      <img
        src={src.src}
        alt={alt}
        width={src.width}
        height={src.height}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <Image
        src={src}
        alt={alt}
        widths={[480, 800, 1200]}
        sizes={sizes}
        loading="lazy"
      />
    )
  }
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure {
    margin-block: 2.4em;
    /* let the figure span a touch wider than the 38rem prose column */
    width: min(100%, 44rem);
    margin-inline: auto;
  }
  .figure--wide {
    width: min(100%, 52rem);
  }
  .figure :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius);
    border: 1px solid var(--line-700);
    background: var(--night-700);
    box-shadow: 0 22px 60px -34px rgba(0, 0, 0, 0.95),
      0 0 50px -30px rgba(143, 185, 168, 0.35);
  }
  figcaption {
    margin-top: 0.85rem;
    text-align: center;
    font-size: var(--step--1);
    line-height: 1.5;
    color: var(--muted-400);
    font-style: italic;
    max-width: 40ch;
    margin-inline: auto;
  }
</style>
