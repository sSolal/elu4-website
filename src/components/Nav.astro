---
/**
 * Site navigation. The lamp-mark + wordmark return home; three quiet links.
 */
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const links = [
  { href: '/', label: 'The Game' },
  { href: '/open', label: 'Open Source' },
  { href: '/dimension', label: 'Four dimensions?' },
];
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="nav">
  <div class="wrap nav__inner">
    <a href="/" class="brand" aria-label="Elua — home">
      <svg class="brand__mark" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="16" cy="16" r="13" class="ring ring--outer" />
        <circle cx="16" cy="16" r="8" class="ring ring--inner" />
        <circle cx="16" cy="16" r="2.4" class="core" />
      </svg>
      <span class="brand__word">Elua</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav__links">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                class:list={['nav__link', { 'is-active': isActive(l.href) }]}
                aria-current={isActive(l.href) ? 'page' : undefined}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
    background: linear-gradient(
      180deg,
      rgba(7, 10, 18, 0.82),
      rgba(7, 10, 18, 0.35) 80%,
      transparent
    );
    border-bottom: 1px solid rgba(36, 50, 70, 0.5);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 64px;
    padding-block: 0.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    color: var(--ink-strong);
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .brand:hover {
    text-decoration: none;
    color: var(--ink-strong);
  }
  .brand__word {
    background: linear-gradient(180deg, var(--ceramic-100), var(--lamp-300));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .brand__mark {
    width: 30px;
    height: 30px;
    overflow: visible;
  }
  .brand__mark .ring {
    fill: none;
    stroke: var(--lamp-500);
    stroke-width: 1.3;
    opacity: 0.85;
    transform-origin: 16px 16px;
  }
  .brand__mark .ring--inner {
    stroke: var(--drift-400);
    opacity: 0.7;
  }
  .brand__mark .core {
    fill: var(--lamp-300);
    filter: drop-shadow(0 0 5px rgba(246, 215, 159, 0.8));
  }
  .brand:hover .ring--outer {
    animation: spin 9s linear infinite;
  }
  .brand:hover .ring--inner {
    animation: spin 6s linear infinite reverse;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: clamp(0.8rem, 2.5vw, 2rem);
    list-style: none;
    padding: 0;
  }
  .nav__link {
    color: var(--ceramic-300);
    font-size: var(--step--1);
    font-weight: 540;
    letter-spacing: 0.02em;
    padding-block: 0.3em;
    position: relative;
    white-space: nowrap;
  }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    height: 1px;
    width: 0;
    background: var(--accent);
    transition: width 0.25s var(--ease);
  }
  .nav__link:hover {
    color: var(--lamp-300);
    text-decoration: none;
  }
  .nav__link:hover::after,
  .nav__link.is-active::after {
    width: 100%;
  }
  .nav__link.is-active {
    color: var(--ceramic-100);
  }

  @media (max-width: 540px) {
    .brand__word {
      display: none;
    }
    .nav__links {
      font-size: 0.8rem;
    }
    .nav__link {
      letter-spacing: 0;
    }
  }
</style>
